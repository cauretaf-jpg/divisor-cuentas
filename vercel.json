{
  "cleanUrls": true,
  "trailingSlash": false,
  "rewrites": [
    { "source": "/", "destination": "/index.html" },
    { "source": "/app", "destination": "/app.html" },
    { "source": "/perfil", "destination": "/perfil.html" },
    { "source": "/como-funciona", "destination": "/como-funciona.html" },
    { "source": "/funciones", "destination": "/funciones.html" },
    { "source": "/preguntas-frecuentes", "destination": "/preguntas-frecuentes.html" },
    { "source": "/privacidad", "destination": "/privacidad.html" },
    { "source": "/terminos", "destination": "/terminos.html" },
    { "source": "/contacto", "destination": "/contacto.html" }
  ],
  "headers": [
    {
      "source": "/service-worker.js",
      "headers": [
        { "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate" }
      ]
    },
    {
      "source": "/manifest.json",
      "headers": [
        { "key": "Cache-Control", "value": "no-cache" }
      ]
    }
  ]
}
