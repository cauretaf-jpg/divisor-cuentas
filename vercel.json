{
  "rewrites": [
    {
      "source": "/app",
      "destination": "/app.html"
    },
    {
      "source": "/como-funciona",
      "destination": "/como-funciona.html"
    },
    {
      "source": "/funciones",
      "destination": "/funciones.html"
    },
    {
      "source": "/preguntas-frecuentes",
      "destination": "/preguntas-frecuentes.html"
    },
    {
      "source": "/privacidad",
      "destination": "/privacidad.html"
    },
    {
      "source": "/terminos",
      "destination": "/terminos.html"
    },
    {
      "source": "/contacto",
      "destination": "/contacto.html"
    },
    {
      "source": "/perfil",
      "destination": "/perfil.html"
    }
  ],
  "headers": [
    {
      "source": "/service-worker.js",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "no-cache"
        }
      ]
    },
    {
      "source": "/manifest.json",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "no-cache"
        }
      ]
    }
  ]
}
